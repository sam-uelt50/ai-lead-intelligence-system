"@ | Out-File -FilePath ".env" -Encoding UTF8

# Create .env.example with placeholders
@"
# MongoDB Connection - REPLACE WITH YOUR VALUES
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# API Settings
DEBUG=True
PORT=8000
HOST=0.0.0.0

# Application Settings
APP_NAME=Agency Lead Intelligence System
APP_VERSION=1.0.0

# Database Settings
DATABASE_NAME=agency_intel
DATABASE_USER=your_mongodb_username
DATABASE_PASSWORD=your_mongodb_password
DATABASE_CLUSTER=your_cluster_name

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=change-this-to-a-random-string
API_KEY=your-api-key-for-external-services

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Optional API Keys (for future integrations)
# OPENAI_API_KEY=your_openai_api_key_here
# LINKEDIN_API_KEY=your_linkedin_api_key_here
# CRUNCHBASE_API_KEY=your_crunchbase_api_key_here
# NEWS_API_KEY=your_newsapi_key_here
"@ | Out-File -FilePath ".env.example" -Encoding UTF8

Write-Host "✅ .env and .env.example files created successfully!" -ForegroundColor Green
Write-Host ""
Write-Host "📁 .env file contains YOUR actual credentials" -ForegroundColor Yellow
Write-Host "📁 .env.example contains placeholder values for sharing" -ForegroundColor Yellow